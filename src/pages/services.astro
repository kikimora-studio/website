---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Hero from "~/components/Hero.astro";
import { Picture } from "astro:assets";
import Badge from "~/components/Badge.astro";
import Heading from "~/components/Heading.astro";

import equipment1 from "~/assets/images/kikimora/equipment-1.jpg";
import equipment2 from "~/assets/images/kikimora/equipment-2-bodyshape.jpg";
---

<Layout title="Services - Kikimora Studio" pageTitle="Services | Kikimora Studio" description="Reformer Pilates and Bodyshape V2 services">
	<Section class:list={"bg-white"}>
		<div x-data>
			<Heading>
				<h1 slot="heading-title" class="font-black text-brand-green h2">
					<span x-show="$store.lang.current === 'bg'">Нашите услуги</span>
					<span x-show="$store.lang.current === 'en'" x-cloak>Our Services</span>
				</h1>
				<p slot="heading-content">
					<span x-show="$store.lang.current === 'bg'">Модерно оборудване за вашето здраве и красота</span>
					<span x-show="$store.lang.current === 'en'" x-cloak>Modern equipment for your health and beauty</span>
				</p>
			</Heading>
		</div>
	</Section>

	<!-- Reformer Pilates -->
	<Section class:list={"bg-white"}>
		<Hero>
			<div slot="hero-content-left" class="prose max-w-none max-lg:order-1" x-data>
				<Badge title="Reformer Pilates" />
				<h2 class="font-black text-brand-green">Reformer Pilates</h2>

				<p>
					<span x-show="$store.lang.current === 'bg'">Reformer Pilates е уред, който комбинира стабилност и динамика. Състои се от подвижна платформа (каретка), която се движи по релси, пружини с различно съпротивление, които регулират натоварването, въжета, ремъци и стойки за ръце и крака, осигуряващи свобода на движенията.</span>
					<span x-show="$store.lang.current === 'en'" x-cloak>The Reformer Pilates machine combines stability and dynamics. It consists of a moving platform (carriage) that slides on rails, springs with varying resistance to regulate load, ropes, straps and foot/hand bars ensuring freedom of movement.</span>
				</p>

				<p class="font-medium text-brand-green">
					<span x-show="$store.lang.current === 'bg'">6 уреда | На всеки кръгъл час до 20:00ч | Начинаещи & Напреднали</span>
					<span x-show="$store.lang.current === 'en'" x-cloak>6 machines | Every hour until 8:00 PM | Beginner & Advanced</span>
				</p>

				<ul x-data>
					<template x-if="$store.lang.current === 'bg'">
						<div>
							<li>Подобрява стойката и гъвкавостта</li>
							<li>Укрепва дълбоките мускули</li>
							<li>Намалява болките в гърба</li>
							<li>Подходящ за всички нива</li>
							<li>Нисък риск от травми</li>
						</div>
					</template>
					<template x-if="$store.lang.current === 'en'">
						<div>
							<li>Improves posture and flexibility</li>
							<li>Strengthens deep muscles</li>
							<li>Reduces back pain</li>
							<li>Suitable for all levels</li>
							<li>Low risk of injury</li>
						</div>
					</template>
				</ul>
			</div>
			<div slot="hero-content-right">
				<Picture
					class:list={"mx-auto rounded-2xl shadow-lg"}
					src={equipment1}
					width={600}
					formats={["avif", "webp"]}
					alt="Reformer Pilates equipment"
				/>
			</div>
		</Hero>
	</Section>

	<!-- Bodyshape V2 -->
	<Section class:list={"bg-white"}>
		<Hero>
			<div slot="hero-content-left" class="prose max-w-none lg:order-2" x-data>
				<Badge color="red" title="Bodyshape V2" />
				<h2 class="font-black text-brand-red">Bodyshape V2</h2>
				<p class="text-brand-red font-semibold italic text-xl">
					<span x-show="$store.lang.current === 'bg'">Иновативна фитнес технология</span>
					<span x-show="$store.lang.current === 'en'" x-cloak>Innovative Fitness Technology</span>
				</p>

				<p>
					<span x-show="$store.lang.current === 'bg'">Bodyshape е уникално устройство, което свързва кардио тренировка с грижа за цялото тяло и кожата. Тази анти-гравитационна бягаща пътека комбинира лимфен дренаж, благодарение на вакуумния масаж под налягане и инфрачервената топлинна терапия, като по този начин насърчава загубата на тегло и намаляването на целулита.</span>
					<span x-show="$store.lang.current === 'en'" x-cloak>Bodyshape is a unique device that combines cardio training with full body and skin care. This anti-gravity treadmill combines lymphatic drainage through vacuum pressure massage and infrared thermal therapy, promoting weight loss and cellulite reduction.</span>
				</p>

				<p>
					<span x-show="$store.lang.current === 'bg'">Чрез модерната технология за вакуумна компресия и инфрачервена технология, устройството активира способността на тялото ви да изгаря специфични области на мазнините и целулита.</span>
					<span x-show="$store.lang.current === 'en'" x-cloak>Through modern vacuum compression and infrared technology, the device activates your body's ability to burn specific areas of fat and cellulite.</span>
				</p>

				<div class="grid grid-cols-2 gap-2 not-prose" x-data>
					<template x-if="$store.lang.current === 'bg'">
						<div class="contents">
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Анти-гравитационна бягаща пътека</div>
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Ароматерапия</div>
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Озонотерапия</div>
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Цветотерапия</div>
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Колагенна лампа</div>
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Инфрачервена терапия</div>
						</div>
					</template>
					<template x-if="$store.lang.current === 'en'">
						<div class="contents">
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Anti-gravity treadmill</div>
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Aromatherapy</div>
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Ozone therapy</div>
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Color therapy</div>
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Collagen lamp</div>
							<div class="bg-brand-red/5 rounded-lg p-3 text-center text-sm font-medium text-brand-red">Infrared therapy</div>
						</div>
					</template>
				</div>

				<p class="text-brand-red font-medium mt-4">
					<span x-show="$store.lang.current === 'bg'">Сесии от 30 минути | За начинаещи и напреднали</span>
					<span x-show="$store.lang.current === 'en'" x-cloak>30-minute sessions | For beginners and advanced</span>
				</p>
			</div>
			<div slot="hero-content-right">
				<Picture
					class:list={"mx-auto rounded-2xl shadow-lg"}
					src={equipment2}
					width={600}
					formats={["avif", "webp"]}
					alt="Bodyshape V2 innovative fitness technology"
				/>
			</div>
		</Hero>
	</Section>
</Layout>
