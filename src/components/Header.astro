---
import { menuMain } from "~/data/menus.js";
import { Image } from "astro:assets";
import logo from "~/assets/images/kikimora/kiki-yoga-1024-transparent.png";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const rmTrailingSlash = (path: string): string => {
  return path.endsWith("/") && path.length > 1
    ? path.slice(0, path.length - 1)
    : path;
}

const pathname = rmTrailingSlash(Astro.url.pathname);

const prefixUrl = (url: string) => url === '/' ? (base || '/') : `${base}${url}`;
---

<header x-data="{ open: false }" @keydown.window.escape="open = false">
	<div class="container py-4">
		<nav class="flex items-center justify-between" aria-label="Global">
			<a href={prefixUrl('/')} class="-m-1.5 p-1.5 flex items-center gap-3">
				<Image src={logo} alt="Kikimora Studio" width={48} height={48} class="rounded-full bg-white p-0.5 shadow" />
				<span class="font-bold text-2xl text-brand-green dark:text-brand-green/90">Kikimora <span class="text-brand-red dark:text-brand-red/90">Studio</span></span>
			</a>
			<div class="flex items-center gap-3 lg:hidden">
				<button
					type="button"
					class="p-1.5 rounded-full text-brand-green hover:bg-brand-green/10 transition"
					x-data
					@click="$store.dark.toggle()"
					aria-label="Toggle dark mode"
				>
					<svg x-show="!$store.dark.on" class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" /></svg>
					<svg x-show="$store.dark.on" x-cloak class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>
				</button>
				<button
					type="button"
					class="px-3 py-1 rounded-full text-sm font-bold border-2 border-brand-green text-brand-green hover:bg-brand-green hover:text-white transition"
					x-data
					@click="$store.lang.toggle()"
					x-text="$store.lang.current === 'bg' ? 'EN' : 'BG'"
				>EN</button>
				<button
					type="button"
					class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5"
					@click="open = true"
				>
					<span class="sr-only">Open main menu</span>
					<svg class="size-8 text-brand-green" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
					</svg>
				</button>
			</div>
			<div class="hidden lg:flex lg:gap-x-8 lg:items-center">
				{
					menuMain.map((item) => (
						<a
							href={prefixUrl(item.url)}
							class={`transition text-base/6 font-semibold hover:text-brand-green dark:text-gray-300 dark:hover:text-brand-green ${item.highlighted ? "menu-item-highlighted" : ""} ${pathname === item.url ? "menu-item-active" : ""}`}
							x-data
							x-text={`$store.lang.current === 'bg' ? '${item.nameBg}' : '${item.name}'`}
						>
							{item.name}
						</a>
					))
				}
				<button
					type="button"
					class="p-1.5 rounded-full text-brand-green hover:bg-brand-green/10 transition"
					x-data
					@click="$store.dark.toggle()"
					aria-label="Toggle dark mode"
				>
					<svg x-show="!$store.dark.on" class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" /></svg>
					<svg x-show="$store.dark.on" x-cloak class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>
				</button>
				<button
					type="button"
					class="px-3 py-1 rounded-full text-sm font-bold border-2 border-brand-green text-brand-green hover:bg-brand-green hover:text-white transition"
					x-data
					@click="$store.lang.toggle()"
					x-text="$store.lang.current === 'bg' ? 'EN' : 'BG'"
				>EN</button>
			</div>
		</nav>
		<div class="lg:hidden" x-ref="dialog" x-show="open" x-cloak aria-modal="true">
			<div
				class="fixed inset-0 z-50 w-full overflow-y-auto bg-white px-8 py-6"
				x-show="open"
				x-transition:enter="transition ease-out"
				x-transition:enter-start="opacity-0"
				x-transition:enter-end="opacity-100"
				x-transition:leave="transition ease-in"
				x-transition:leave-start="opacity-100"
				x-transition:leave-end="opacity-0"
				x-cloak
			>
				<div class="flex items-center justify-between">
					<a href={prefixUrl('/')} class="-m-1.5 p-1.5 flex items-center gap-3">
						<Image src={logo} alt="Kikimora Studio" width={48} height={48} class="rounded-full bg-white p-0.5 shadow" />
						<span class="font-bold text-2xl text-brand-green">Kikimora <span class="text-brand-red">Studio</span></span>
					</a>
					<button type="button" class="-m-2.5 p-2.5 text-brand-red" @click="open = false">
						<span class="sr-only">Close menu</span>
						<svg class="size-8" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
						</svg>
					</button>
				</div>
				<div class="mt-6 flow-root">
					<div class="-my-6 divide-y divide-gray-500/10">
						<div class="space-y-2 py-6 mt-16">
							{
								menuMain.map((item) => (
									<a
										@click="open = false"
										href={prefixUrl(item.url)}
										class={`block py-2 text-center font-semibold text-3xl ${item.highlighted ? "menu-item-highlighted w-max mx-auto !px-8 !py-2" : ""} ${pathname === item.url ? "menu-item-active" : ""}`}
										x-text={`$store.lang.current === 'bg' ? '${item.nameBg}' : '${item.name}'`}
									>
										{item.name}
									</a>
								))
							}
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</header>
